{
  "name": "sybyl",
  "version": "0.1.0",
  "description": "Obsidian plugin for solo tabletop play with Lonelog support",
  "license": "MIT",
  "author": "Roberto Bisceglie",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs",
    "check": "tsc --noEmit",
    "test": "tsc --noEmit",
    "version": "node -e \"const fs=require('fs');const m=JSON.parse(fs.readFileSync('manifest.json','utf8'));m.version=process.env.npm_package_version;fs.writeFileSync('manifest.json',JSON.stringify(m,null,2)+'\\n');\" && git add manifest.json"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  }
}
